DATABASE_URL=postgresql://kemis:kemis@localhost:5434/kemisdisplay
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRE_MINUTES=10080
CORS_ORIGINS=http://localhost:3000,https://kemisdisplay.com
# No trailing slash. On Railway use your service URL (same value you put in Vercel NEXT_PUBLIC_API_URL).
PUBLIC_API_BASE_URL=http://localhost:8000
UPLOAD_DIR=./storage/uploads
# Temp workspace for menu video renders (WebM/MP4); cleared per job.
MENU_RENDER_TMP=./storage/menu_render_tmp
# Set to 1 locally to ignore trial/plan limits (never in production).
DEV_BYPASS_BILLING=0
# Comma-separated emails to grant is_admin on API startup (users must already exist).
ADMIN_EMAILS=
