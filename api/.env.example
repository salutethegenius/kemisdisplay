DATABASE_URL=postgresql://kemis:kemis@localhost:5434/kemisdisplay
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRE_MINUTES=10080
CORS_ORIGINS=http://localhost:3000,https://kemisdisplay.com
# No trailing slash. On Railway use your service URL (same value you put in Vercel NEXT_PUBLIC_API_URL).
PUBLIC_API_BASE_URL=http://localhost:8000
UPLOAD_DIR=./storage/uploads
# Temp workspace for menu video renders (WebM/MP4); cleared per job.
MENU_RENDER_TMP=./storage/menu_render_tmp
# Set to 1 locally to ignore trial/plan limits (never in production).
DEV_BYPASS_BILLING=0
# Comma-separated emails to grant is_admin on API startup (users must already exist).
ADMIN_EMAILS=

# Mux Video (optional). When MUX_TOKEN_ID and MUX_TOKEN_SECRET are set, new videos use Mux.
MUX_TOKEN_ID=
MUX_TOKEN_SECRET=
# From Mux → Webhooks → signing secret. Required for POST /mux/webhook verification.
MUX_WEBHOOK_SIGNING_SECRET=

# Cloudflare R2 (S3-compatible). Videos at or below VIDEO_MUX_THRESHOLD_MB use R2 when fully configured.
# Image uploads require full R2 configuration (public URLs); there is no Railway-safe disk fallback for images.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=kemisdisplay-media
# Public base URL for objects (custom domain or r2.dev), no trailing slash.
R2_PUBLIC_URL=
# Videos larger than this (MB) route to Mux when Mux credentials are set; smaller use R2 when R2 is set.
VIDEO_MUX_THRESHOLD_MB=50

# Sentry (optional). Leave unset to disable. Use the same DSN as web or an API-only project.
SENTRY_DSN=
# SENTRY_TRACES_SAMPLE_RATE=0

# Stripe Billing (Starter $25/mo). Live keys for production.
# Product: KemisDisplay Starter — price_1Tu2t42a7Qn43sncBvarThae
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_STARTER=price_1Tu2t42a7Qn43sncBvarThae
# Checkout success/cancel + Customer Portal return URL base (no trailing slash).
WEB_APP_URL=https://kemisdisplay.com
