# FastAPI base (local or Railway). On Vercel this MUST be your Railway service URL, e.g.
# https://your-api.up.railway.app — NOT https://www.kemisdisplay.com (that causes 404 on /auth/*).
NEXT_PUBLIC_API_URL=http://localhost:8000
# Public site origin (no trailing slash). Used for canonical URLs, sitemap, OG — in production set to https://www.kemisdisplay.com or https://kemisdisplay.com
NEXT_PUBLIC_APP_URL=http://localhost:3000
