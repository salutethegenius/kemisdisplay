# FastAPI base (local or Railway). On Vercel this MUST be your Railway service URL, e.g.
# https://your-api.up.railway.app — NOT https://www.kemisdisplay.com (that causes 404 on /auth/*).
NEXT_PUBLIC_API_URL=http://localhost:8000
# Public site origin (no trailing slash). Used for canonical URLs, sitemap, OG — in production set to https://www.kemisdisplay.com or https://kemisdisplay.com
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Sentry (https://sentry.io). Build uses org kgc-dr / project kemisdisplay; set in Vercel for production. Optional locally.
# NEXT_PUBLIC_SENTRY_DSN=
# Optional: SENTRY_AUTH_TOKEN in CI for source map upload (Vercel env; never commit).

# Support links (dashboard Support page + Account). Defaults to legal@kemisdisplay.com if email unset.
# NEXT_PUBLIC_SUPPORT_EMAIL=
# NEXT_PUBLIC_SUPPORT_WHATSAPP_URL=https://wa.me/15551234567

# Temporary: set to 1 so /sentry-example-page exists on a deployed build for Sentry verification; unset afterward.
# NEXT_PUBLIC_SENTRY_TEST_PAGE=1
